manifest {
    name            = 'variant-scan'
    description     = 'Scan multiple VCF files for a target variant across a population'
    version         = '0.1.0'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
}

params {
    input           = null
    outdir          = 'results'

    variant_name    = null
    variant_chrom   = null
    variant_pos     = null
    variant_ref     = null
    variant_alt     = null
    variant_min_af  = 0.0
    variant_max_af  = 1.0
}

process {
    executor = 'local'
    cpus     = 1
    memory   = '1.GB'

    withName: 'INSPECT_VCF|SCAN_VARIANT' {
        cpus   = 1
        memory = '1.GB'
    }
    withName: 'METADATA_REPORT|VARIANT_REPORT' {
        cpus   = 1
        memory = '512.MB'
    }
}

executor {
    name      = 'local'
    queueSize = 16
}

profiles {
    standard {
        // Defaults above — suitable for a mid-size VM.
    }
    small_vm {
        executor.queueSize = 4
    }
    big_vm {
        executor.queueSize = 32
    }
}
